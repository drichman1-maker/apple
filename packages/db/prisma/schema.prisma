generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Product {
  id           String          @id @default(cuid())
  site         Site
  name         String
  slug         String
  category     String?
  msrp         Float?
  specs        Json?
  imageUrl     String?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  Alert        Alert[]
  priceHistory PriceHistory[]
  prices       RetailerPrice[]

  @@unique([site, slug], name: "site_slug")
  @@index([site])
}

model RetailerPrice {
  id           String      @id @default(cuid())
  productId    String
  retailer     String
  price        Float
  status       StockStatus @default(in_stock)
  url          String
  affiliateUrl String?
  verified     Boolean     @default(false)
  updatedAt    DateTime    @updatedAt
  product      Product     @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, retailer], name: "productId_retailer")
  @@index([productId])
}

model PriceHistory {
  id        String       @id @default(cuid())
  productId String
  retailer  String
  oldPrice  Float?
  newPrice  Float
  oldStatus StockStatus?
  newStatus StockStatus?
  changedAt DateTime     @default(now())
  changedBy ChangedBy    @default(manual)
  product   Product      @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([changedAt])
  @@index([productId])
}

model AffiliateClick {
  id        String   @id @default(cuid())
  productId String
  retailer  String
  site      Site
  clickedAt DateTime @default(now())

  @@index([productId])
  @@index([site, clickedAt])
}

model Alert {
  id          String    @id
  productId   String
  email       String
  targetPrice Float?
  isActive    Boolean   @default(true)
  triggeredAt DateTime?
  createdAt   DateTime  @default(now())
  Product     Product   @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([email])
  @@index([productId])
}

model EmailSubscription {
  id        String   @id
  email     String
  site      Site
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  @@unique([email, site])
}

enum Site {
  theresmac
  gpudrip
  healthindex
  babygear
  rumbledeals
  robotatlas
}

enum StockStatus {
  in_stock
  out_of_stock
  backordered
  not_carried
}

enum ChangedBy {
  manual
  scraper
  import
}
