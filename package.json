{
  "name": "agg-monorepo",
  "private": true,
  "version": "0.0.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "check-types": "turbo check-types",
    "format": "prettier --write .",
    "scrape:theresmac": "npm run scrape:theresmac -w packages/scraper",
    "scrape:gpudrip": "npm run scrape:gpudrip -w packages/scraper",
    "scrape:all": "npm run scrape:all -w packages/scraper"
  },
  "devDependencies": {
    "prettier": "^3.0.0",
    "turbo": "^2.0.0",
    "typescript": "5.9.2"
  }
}
