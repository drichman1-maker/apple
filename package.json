{
  "name": "agg-monorepo",
  "private": true,
  "version": "0.0.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "turbo lint",
    "check-types": "turbo check-types",
    "format": "prettier --write .",
    "turbo:dev": "turbo dev",
    "turbo:build": "turbo build",
    "scrape:theresmac": "npm run scrape:theresmac -w packages/scraper",
    "scrape:gpudrip": "npm run scrape:gpudrip -w packages/scraper",
    "scrape:all": "npm run scrape:all -w packages/scraper"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "lucide-react": "^0.323.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-helmet-async": "^2.0.5",
    "react-router-dom": "^6.22.0",
    "recharts": "^2.12.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^3.1.0",
    "autoprefixer": "^10.4.17",
    "postcss": "^8.4.35",
    "prettier": "^3.0.0",
    "tailwindcss": "^3.4.1",
    "turbo": "^2.0.0",
    "typescript": "5.9.2",
    "vite": "^4.5.0"
  }
}
